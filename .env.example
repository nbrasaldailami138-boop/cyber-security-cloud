# ==================== قاعدة البيانات ====================
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres?pgbouncer=true"

# ==================== Supabase ====================
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_[YOUR-KEY]"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_[YOUR-KEY]"

# ==================== ImageKit (تخزين الملفات) ====================
IMAGEKIT_PRIVATE_KEY="private_[YOUR-KEY]"
IMAGEKIT_PUBLIC_KEY="public_[YOUR-KEY]"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/[YOUR-ID]"

# ==================== Brevo (البريد الإلكتروني) ====================
BREVO_API_KEY="xkeysib-[YOUR-KEY]"
BREVO_SMTP_KEY="xsmtpsib-[YOUR-KEY]"
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER="[YOUR-SMTP-USER]"
BREVO_FROM_EMAIL="[YOUR-EMAIL]"
BREVO_FROM_NAME="سحابة الأمن السيبراني"

# ==================== Upstash Redis (Rate Limiting) ====================
UPSTASH_REDIS_REST_URL="https://[YOUR-INSTANCE].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[YOUR-TOKEN]"

# ==================== JWT ====================
JWT_ACCESS_SECRET="[GENERATE-RANDOM-64-CHARS]"
JWT_REFRESH_SECRET="[GENERATE-RANDOM-64-CHARS]"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ==================== التشفير ====================
ENCRYPTION_KEY="[GENERATE-RANDOM-32-CHARS]"

# ==================== Sentry (اختياري) ====================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ==================== التطبيق ====================
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="سحابة الأمن السيبراني"
NEXT_PUBLIC_UNIVERSITY="جامعة ذمار - كلية الحاسبات"

# ==================== Web Push (VAPID) ====================
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[GENERATE-VAPID-KEYS]"
VAPID_PRIVATE_KEY="[GENERATE-VAPID-KEYS]"

# ==================== hCaptcha ====================
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000000"
HCAPTCHA_SECRET_KEY="0x0000000000000000000000000000000000000000"

# ==================== البيئة ====================
NODE_ENV="production"

# ==================== JDoodle (محرر الأكواد) ====================
JDOODLE_CLIENT_ID="[YOUR-CLIENT-ID]"
JDOODLE_CLIENT_SECRET="[YOUR-CLIENT-SECRET]"
