generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== الأدوار ====================
enum UserRole {
  ADMIN
  MANAGEMENT
  TEACHER
  STUDENT
}

enum AcademicLevel {
  LEVEL_1
  LEVEL_2
}

enum Semester {
  TERM_1
  TERM_2
}

enum AccountStatus {
  PENDING
  ACTIVE
  LOCKED
  SUSPENDED
}

// ==================== المستخدمين ====================
model User {
  id                 String        @id @default(uuid())
  name               String
  email              String        @unique
  passwordHash       String
  role               UserRole
  level              AcademicLevel?
  status             AccountStatus @default(PENDING)
  activationCodeHash String?
  activationExpires  DateTime?
  isActivated        Boolean       @default(false)
  twoFactorEnabled   Boolean       @default(false)
  twoFactorSecret    String?
  webAuthnEnabled    Boolean       @default(false)
  webAuthnCredential String?
  webAuthnDeviceId   String?
  lastLoginAt        DateTime?
  lastSeenAt         DateTime?
  managementLevel    AcademicLevel?
  lastLoginIp        String?
  failedLoginAttempts Int          @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  // العلاقات
  messagesSent           Message[]     @relation("SentMessages")
  messagesReceived       Message[]     @relation("ReceivedMessages")
  notifications          Notification[]
  auditLogs              AuditLog[]
  publishedContent       Content[]
  publishedAnnouncements Announcement[]
  gradeDistributions     GradeDistribution[]
  uploadPermissions      UploadPermission[]
  sentAssignments        Assignment[]
  evaluatedAssignments   Assignment[]     @relation("EvaluatedAssignments")
  sessions               Session[]
  subjectsTaught         Subject[]        @relation("TeacherSubjects")
  promotionRequests      PromotionRequest[] @relation("PromotionRequestedBy")

  @@map("users")
}

// ==================== الجلسات ====================
model Session {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String    @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@map("sessions")
}

// ==================== المواد الدراسية ====================
model Subject {
  id        String        @id @default(uuid())
  name      String
  code      String        @unique
  level     AcademicLevel
  semester  Semester      @default(TERM_1)
  isActive  Boolean       @default(true)
  teacherId String?
  teacher   User?         @relation("TeacherSubjects", fields: [teacherId], references: [id])
  createdAt DateTime      @default(now())
  deletedAt DateTime?

  assignments   Assignment[]
  content       Content[]
  gradeDistributions GradeDistribution[]

  @@map("subjects")
}

// ==================== الرسائل ====================
model Message {
  id               String    @id @default(uuid())
  senderId         String
  receiverId       String
  subject          String?
  body             String
  encrypted        Boolean   @default(false)
  isRead           Boolean   @default(false)
  isEdited         Boolean   @default(false)
  isBlocked        Boolean   @default(false)
  senderDeleted    Boolean   @default(false)
  receiverDeleted  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  sender       User      @relation("SentMessages", fields: [senderId], references: [id])
  receiver     User      @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}

// ==================== المحتوى التعليمي ====================
enum ContentType {
  PDF
  DOCX
  XLSX
  PNG
  JPG
  YOUTUBE_LINK
}

model Content {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        ContentType
  fileUrl     String?
  youtubeUrl  String?
  fileSize    Int?
  
  subjectId   String?
  subject     Subject?    @relation(fields: [subjectId], references: [id])
  level       AcademicLevel
  semester    Semester    @default(TERM_1)
  publisherId String
  publisher   User        @relation(fields: [publisherId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  version     Int         @default(1)

  @@map("content")
}

// ==================== التعميمات ====================
model Announcement {
  id          String        @id @default(uuid())
  title       String
  description String
  level       AcademicLevel
  publisherId String
  publisher   User          @relation(fields: [publisherId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@map("announcements")
}

// ==================== التكاليف ====================
model Assignment {
  id            String       @id @default(uuid())
  studentId     String
  student       User         @relation(fields: [studentId], references: [id])
  subjectId     String
  subject       Subject      @relation(fields: [subjectId], references: [id])
  fileUrl       String
  fileName      String
  fileSize      Int
  grade         Float?
  feedback      String?
  evaluatedAt   DateTime?
  evaluatorId   String?
  evaluator     User?        @relation("EvaluatedAssignments", fields: [evaluatorId], references: [id])
  status        String       @default("pending")
  semester      Semester     @default(TERM_1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@map("assignments")
}

// ==================== توزيع الدرجات ====================
model GradeDistribution {
  id          String        @id @default(uuid())
  teacherId   String
  teacher     User          @relation(fields: [teacherId], references: [id])
  subjectId   String
  subject     Subject       @relation(fields: [subjectId], references: [id])
  fileUrl     String
  fileName    String
  studentsCount Int
  distributionData Json?
  level       AcademicLevel
  semester    Semester      @default(TERM_1)
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?

  @@map("grade_distributions")
}

// ==================== الإشعارات ====================
enum NotificationType {
  NEW_MESSAGE
  ASSIGNMENT_EVALUATED
  NEW_ASSIGNMENT
  NEW_ANNOUNCEMENT
  NEW_CONTENT
  GRADES_DISTRIBUTED
  ACCOUNT_MODIFIED
  LEVEL_PROMOTED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ==================== صلاحيات الرفع ====================
model UploadPermission {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  grantedBy String
  grantedAt DateTime @default(now())
  revokedAt DateTime?

  @@map("upload_permissions")
}

// ==================== سجل العمليات ====================
enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  UPLOAD
  DOWNLOAD
  EVALUATE
  PUBLISH
  FAILED_LOGIN
  SUSPICIOUS_ACTIVITY
  LEVEL_PROMOTION
  SEMESTER_SWITCH
}

enum SeverityLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AuditLog {
  id          String        @id @default(uuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  action      AuditAction
  severity    SeverityLevel @default(INFO)
  description String
  ipAddress   String?
  deviceInfo  String?
  level       AcademicLevel?
  metadata    Json?
  createdAt   DateTime      @default(now())

  @@map("audit_logs")
}

// ==================== رموز التفعيل ====================
model ActivationCode {
  id        String        @id @default(uuid())
  codeHash  String        @unique
  level     AcademicLevel
  role      UserRole
  subjectId String?
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime      @default(now())
  expiresAt DateTime

  @@map("activation_codes")
}

// ==================== طلبات ترقية المستوى ====================
enum PromotionStatus {
  PENDING
  APPROVED
  REJECTED
}

model PromotionRequest {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation("PromotionRequestedBy", fields: [userId], references: [id])
  fromLevel    AcademicLevel
  toLevel      AcademicLevel
  status       PromotionStatus @default(PENDING)
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())

  @@map("promotion_requests")
}

// ==================== سجل التوليد ====================
model GenerationLog {
  id              String        @id @default(uuid())
  name            String
  email           String?
  role            UserRole
  level           AcademicLevel
  code            String
  subjectName     String?
  subjectCode     String?
  semester        Semester?
  generatedById   String
  generatedByName String?
  createdAt       DateTime      @default(now())
  deletedAt       DateTime?

  @@map("generation_logs")
}

// ==================== اشتراكات الإشعارات (PWA Push) ====================
model PushSubscription {
  id         String   @id @default(uuid())
  userId     String   @unique
  endpoint   String
  authKey    String
  p256dhKey  String
  createdAt  DateTime @default(now())

  @@map("push_subscriptions")
}

// ==================== إعدادات النظام ====================
model SystemConfig {
  id    String @id @default("system")
  key   String @unique
  value String

  @@map("system_configs")
}
